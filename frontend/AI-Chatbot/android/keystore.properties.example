# Copy to keystore.properties (same folder: frontend/AI-Chatbot/android/).
# NEVER commit keystore.properties with real passwords, or your .jks file.
#
# Create keystore:
#   cd frontend/AI-Chatbot/android
#   keytool -genkeypair -v -keystore release-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias velina
#
# Passwords (pick one approach):
#   A) Environment (recommended):
#        KEYSTORE_PASSWORD          — used for both store and key
#        KEYSTORE_STORE_PASSWORD    — optional; overrides store password only
#        KEYSTORE_KEY_PASSWORD      — optional; overrides key password only
#   B) Inline below for local-only (never commit):

storeFile=release-keystore.jks
keyAlias=velina
# storePassword=YOUR_KEYSTORE_PASSWORD
# keyPassword=YOUR_KEY_PASSWORD
